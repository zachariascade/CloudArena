{
  "name": "cloud-arcanum",
  "version": "0.1.0",
  "private": true,
  "description": "Structured content system for custom MTG-style cards, decks, universes, and sets.",
  "type": "module",
  "scripts": {
    "build": "npm run build:types && npm run build:arcanum:web && npm run build:arena:web",
    "build:types": "./scripts/node18.sh ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "build:arcanum": "npm run build:types && npm run build:arcanum:web",
    "build:arcanum:web": "./scripts/node18.sh dist/scripts/build-web-client.js",
    "build:arena": "npm run build:types && npm run build:arena:web",
    "build:arena:web": "./scripts/node18.sh dist/scripts/build-arena-web-client.js",
    "build:arena:static": "npm run build:types && CLOUD_ARENA_PUBLIC_PATH=./assets npm run build:arena:web && ./scripts/node18.sh dist/scripts/build-arena-static-site.js",
    "preview:arena:static": "npm run build:arena:static && ./scripts/node18.sh dist/scripts/preview-arena-static-site.js",
    "benchmark:api": "npm run build && ./scripts/node18.sh dist/scripts/benchmark-api.js",
    "check": "./scripts/node18.sh ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "dev": "npm run build && ./scripts/node18.sh dist/scripts/dev.js",
    "dev:once": "npm run build && ./scripts/node18.sh dist/scripts/dev.js --no-watch",
    "dev:arcanum": "npm run build:arcanum && ./scripts/node18.sh dist/scripts/dev-arcanum.js",
    "dev:arcanum:once": "npm run build:arcanum && ./scripts/node18.sh dist/scripts/dev-arcanum.js --no-watch",
    "dev:arcanum:api": "npm run build:types && ./scripts/node18.sh dist/scripts/dev-api.js",
    "dev:arcanum:web": "npm run build:arcanum && ./scripts/node18.sh dist/scripts/dev-web.js",
    "dev:api": "npm run dev:arcanum:api",
    "dev:api:once": "npm run dev:arcanum:api",
    "dev:web": "npm run dev:arcanum:web",
    "dev:web:once": "npm run dev:arcanum:web",
    "dev:arena": "npm run build:arena && ./scripts/node18.sh dist/scripts/dev-arena.js",
    "dev:arena:once": "npm run build:arena && ./scripts/node18.sh dist/scripts/dev-arena.js --no-watch",
    "dev:arena:api": "npm run build:types && ./scripts/node18.sh dist/scripts/dev-arena-api.js",
    "dev:arena:web": "npm run build:arena && ./scripts/node18.sh dist/scripts/dev-arena-web.js",
    "arena:demo": "npm run build:types && ./scripts/node18.sh dist/scripts/run-cloud-arena-demo.js",
    "arena:simulate": "npm run build:types && ./scripts/node18.sh dist/scripts/run-cloud-arena-simulation.js",
    "arena:simulate:batch": "npm run build:types && ./scripts/node18.sh dist/scripts/run-cloud-arena-batch-simulation.js",
    "demo:cloud-arena": "npm run arena:demo",
    "simulate:cloud-arena": "npm run arena:simulate",
    "simulate:cloud-arena:batch": "npm run arena:simulate:batch",
    "arcanum:ingest:kjv-exodus": "./scripts/node18.sh dist/scripts/ingest-kjv-exodus.js",
    "arcanum:ingest:kjv-genesis": "./scripts/node18.sh dist/scripts/ingest-kjv-genesis.js",
    "arcanum:ingest:kjv-gospels": "./scripts/node18.sh dist/scripts/ingest-kjv-gospels.js",
    "ingest:kjv-exodus": "npm run arcanum:ingest:kjv-exodus",
    "ingest:kjv-genesis": "npm run arcanum:ingest:kjv-genesis",
    "ingest:kjv-gospels": "npm run arcanum:ingest:kjv-gospels",
    "arcanum:export:card-concepts": "npm run build:types && ./scripts/node18.sh dist/scripts/export-card-concepts.js",
    "arcanum:export:exodus-concepts": "./scripts/node18.sh dist/scripts/export-exodus-card-concepts.js",
    "arcanum:export:genesis-concepts": "./scripts/node18.sh dist/scripts/export-genesis-concepts.js",
    "arcanum:export:gospels-concepts": "./scripts/node18.sh dist/scripts/export-gospels-concepts.js",
    "export:card-concepts": "npm run arcanum:export:card-concepts",
    "export:exodus-concepts": "npm run arcanum:export:exodus-concepts",
    "export:genesis-concepts": "npm run arcanum:export:genesis-concepts",
    "export:gospels-concepts": "npm run arcanum:export:gospels-concepts",
    "arcanum:process:exodus-concepts": "npm run build:types && npm run arcanum:ingest:kjv-exodus && npm run arcanum:export:exodus-concepts",
    "arcanum:process:genesis-concepts": "npm run build:types && npm run arcanum:ingest:kjv-genesis && npm run arcanum:export:genesis-concepts",
    "arcanum:process:gospels-concepts": "npm run build:types && npm run arcanum:ingest:kjv-gospels && npm run arcanum:export:gospels-concepts",
    "process:exodus-concepts": "npm run arcanum:process:exodus-concepts",
    "process:genesis-concepts": "npm run arcanum:process:genesis-concepts",
    "process:gospels-concepts": "npm run arcanum:process:gospels-concepts",
    "test": "./scripts/node18.sh ./node_modules/vitest/vitest.mjs run --pool forks",
    "arcanum:validate": "./scripts/node18.sh --enable-source-maps dist/scripts/validate.js",
    "validate": "npm run arcanum:validate"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^6.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "fastify": "^4.29.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.30.1",
    "zod": "^3.23.8"
  }
}
