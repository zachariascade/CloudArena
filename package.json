{
  "name": "cloud-arcanum",
  "version": "0.1.0",
  "private": true,
  "description": "Structured content system for custom MTG-style cards, decks, universes, and sets.",
  "type": "module",
  "scripts": {
    "build": "./scripts/node18.sh ./node_modules/typescript/bin/tsc -p tsconfig.json && ./scripts/node18.sh dist/scripts/build-web-client.js",
    "benchmark:api": "npm run build && ./scripts/node18.sh dist/scripts/benchmark-api.js",
    "check": "./scripts/node18.sh ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "dev": "npm run build && ./scripts/node18.sh dist/scripts/dev.js",
    "dev:once": "npm run build && ./scripts/node18.sh dist/scripts/dev.js --no-watch",
    "dev:api": "npm run build && ./scripts/node18.sh dist/scripts/dev-api.js",
    "dev:api:once": "npm run build && ./scripts/node18.sh dist/scripts/dev-api.js",
    "dev:web": "npm run build && ./scripts/node18.sh dist/scripts/dev-web.js",
    "dev:web:once": "npm run build && ./scripts/node18.sh dist/scripts/dev-web.js",
    "demo:cloud-arena": "npm run build && ./scripts/node18.sh dist/scripts/run-cloud-arena-demo.js",
    "simulate:cloud-arena": "npm run build && ./scripts/node18.sh dist/scripts/run-cloud-arena-simulation.js",
    "simulate:cloud-arena:batch": "npm run build && ./scripts/node18.sh dist/scripts/run-cloud-arena-batch-simulation.js",
    "ingest:kjv-exodus": "./scripts/node18.sh dist/scripts/ingest-kjv-exodus.js",
    "ingest:kjv-genesis": "./scripts/node18.sh dist/scripts/ingest-kjv-genesis.js",
    "ingest:kjv-gospels": "./scripts/node18.sh dist/scripts/ingest-kjv-gospels.js",
    "export:card-concepts": "npm run build && ./scripts/node18.sh dist/scripts/export-card-concepts.js",
    "export:exodus-concepts": "./scripts/node18.sh dist/scripts/export-exodus-card-concepts.js",
    "export:genesis-concepts": "./scripts/node18.sh dist/scripts/export-genesis-concepts.js",
    "export:gospels-concepts": "./scripts/node18.sh dist/scripts/export-gospels-concepts.js",
    "process:exodus-concepts": "npm run build && npm run ingest:kjv-exodus && npm run export:exodus-concepts",
    "process:genesis-concepts": "npm run build && npm run ingest:kjv-genesis && npm run export:genesis-concepts",
    "process:gospels-concepts": "npm run build && npm run ingest:kjv-gospels && npm run export:gospels-concepts",
    "test": "./scripts/node18.sh ./node_modules/vitest/vitest.mjs run --pool forks",
    "validate": "./scripts/node18.sh --enable-source-maps dist/scripts/validate.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@esbuild/darwin-arm64": "^0.27.4",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^6.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "fastify": "^4.29.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.30.1",
    "zod": "^3.23.8"
  }
}
