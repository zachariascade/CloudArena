{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloud-arena.local/schemas/universe.schema.json",
  "title": "Cloud Arcanum Universe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "description"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^universe_[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
