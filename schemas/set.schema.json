{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloud-arcanum.local/schemas/set.schema.json",
  "title": "Cloud Arcanum Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "universeId",
    "name",
    "code",
    "description"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^set_[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "universeId": {
      "type": "string",
      "pattern": "^universe_[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "code": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "uniqueItems": true
    },
    "defaultThemeId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "activeThemeId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    }
  }
}
