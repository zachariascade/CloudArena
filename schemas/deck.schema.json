{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloud-arena.local/schemas/deck.schema.json",
  "title": "Cloud Arcanum Deck",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "universeId",
    "setIds",
    "format",
    "commander",
    "cards",
    "tags",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^deck_[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "universeId": {
      "type": "string",
      "pattern": "^universe_[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "setIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^set_[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "format": {
      "type": "string",
      "minLength": 1
    },
    "commander": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^card_[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cardId",
          "quantity"
        ],
        "properties": {
          "cardId": {
            "type": "string",
            "pattern": "^card_[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
